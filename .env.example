# Variables para ejecucion local sin Docker
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pse

# Variables usadas por docker-compose.yml
POSTGRES_DB=pse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
API_PORT=8000

# Seguridad JWT
JWT_SECRET_KEY=cambia-esta-clave-jwt-en-produccion
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Backups de Postgres
BACKUP_RETENTION_DAYS=7
BACKUP_TIME=03:00
BACKUP_RUN_ON_STARTUP=false
